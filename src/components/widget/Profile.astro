---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getProfileStats } from "../../utils/content-utils";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
const stats = await getProfileStats();
const formatter = new Intl.NumberFormat("zh-CN");
---
<div class="card-base p-3">
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 "></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{config.name}</div>
        <div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
        <div class="text-center text-neutral-400 mb-2.5 transition">{config.bio}</div>
        <div class="grid grid-cols-3 gap-2 mb-3">
            <div class="rounded-xl bg-black/[0.03] dark:bg-white/[0.04] px-2 py-2 text-center">
                <div class="text-lg font-bold text-black/80 dark:text-white/80 transition">{formatter.format(stats.articleCount)}</div>
                <div class="text-xs text-black/45 dark:text-white/45 transition">{i18n(I18nKey.profileArticles)}</div>
            </div>
            <div class="rounded-xl bg-black/[0.03] dark:bg-white/[0.04] px-2 py-2 text-center">
                <div class="text-lg font-bold text-black/80 dark:text-white/80 transition">{formatter.format(stats.collectionCount)}</div>
                <div class="text-xs text-black/45 dark:text-white/45 transition">{i18n(I18nKey.profileCollections)}</div>
            </div>
            <div class="rounded-xl bg-black/[0.03] dark:bg-white/[0.04] px-2 py-2 text-center">
                <div class="text-lg font-bold text-black/80 dark:text-white/80 transition">{formatter.format(stats.wordCount)}</div>
                <div class="text-xs text-black/45 dark:text-white/45 transition">{i18n(I18nKey.profileWords)}</div>
            </div>
        </div>
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {config.links.map(item =>
                    <a rel="me" aria-label={item.name} href={item.url} target="_blank"
                       class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                        <Icon name={item.icon} class="text-[1.25rem]"></Icon>
                        {item.name}
                    </a>
            )}
        </div>
    </div>
</div>

