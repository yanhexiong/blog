---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { commentConfig, siteConfig } from "@/config";

const commentsEnabled = commentConfig.enable;
const isZh = siteConfig.lang.toLowerCase().startsWith("zh");
const giscusLang = commentConfig.lang || siteConfig.lang.replace("_", "-");
const isConfigured = [
	commentConfig.repo,
	commentConfig.repoId,
	commentConfig.category,
	commentConfig.categoryId,
].every((value) => value.trim().length > 0);
const showSetupNotice = !isConfigured && import.meta.env.DEV;
const showCommentsSection =
	commentsEnabled && (isConfigured || showSetupNotice);

const commentsHelperText = isZh
	? "评论基于 Giscus 和 GitHub Discussions，使用 GitHub 账号即可参与讨论。"
	: "Comments are powered by Giscus and GitHub Discussions. Sign in with your GitHub account to join the conversation.";

const commentsSetupText = isZh
	? "当前还缺少 giscus 的仓库映射参数，请先在 src/config.ts 中补全 repoId、category 和 categoryId。"
	: "Giscus is not fully configured yet. Fill in repoId, category, and categoryId in src/config.ts first.";
---

{showCommentsSection && (
	<section class="mt-8 onload-animation">
		<div class="border-[var(--line-divider)] border-dashed border-b-[1px] mb-6"></div>
		<h2 class="mb-5 text-xl font-bold text-black/90 dark:text-white/90">
			{i18n(I18nKey.comments)}
		</h2>
		<p class="mb-4 text-sm leading-6 text-black/60 dark:text-white/60">
			{commentsHelperText}
		</p>
		{isConfigured ? (
			<div
				class="min-h-[12rem]"
				data-giscus
				data-repo={commentConfig.repo}
				data-repo-id={commentConfig.repoId}
				data-category={commentConfig.category}
				data-category-id={commentConfig.categoryId}
				data-mapping={commentConfig.mapping}
				data-term={commentConfig.term || ""}
				data-strict={commentConfig.strict ? "1" : "0"}
				data-reactions-enabled={commentConfig.reactionsEnabled ? "1" : "0"}
				data-emit-metadata={commentConfig.emitMetadata ? "1" : "0"}
				data-input-position={commentConfig.inputPosition}
				data-theme-light={commentConfig.theme.light}
				data-theme-dark={commentConfig.theme.dark}
				data-lang={giscusLang}
			></div>
		) : (
			<p class="rounded-xl border border-dashed border-[var(--line-divider)] px-4 py-3 text-sm leading-6 text-black/65 dark:text-white/65">
				{commentsSetupText}
			</p>
		)}
	</section>
)}
